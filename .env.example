# 建筑变形监测 Agent · 环境变量模板
#
# 用法：复制本文件为 .env，填入你的 API key，启动应用时会自动加载。
#
# 关键安全提示：
#   - .env 已被 .gitignore 排除，不会被 commit 到仓库
#   - 桌面 GUI 启动后会把 LLM_API_KEY / PADDLE_OCR_TOKEN 迁移到系统 keyring，
#     之后即使删除 .env 也能正常使用（除非清空 keyring）
#   - 团队内分发请走 keyring 或专门的密钥管理，不要传 .env

# ─── LLM 配置（必填）────────────────────────────────────────
# OpenAI 兼容协议；MiniMax / DashScope / Kimi / GLM 等都可
LLM_API_KEY=sk-换成你自己的-key
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7-highspeed

# ─── PaddleOCR 配置（仅扫描件需要）─────────────────────────
# 默认使用 https://aistudio.baidu.com/ 的 PaddleOCR-VL 服务
PADDLE_OCR_TOKEN=换成你自己的-paddle-token
PADDLE_OCR_MODEL=PaddleOCR-VL-1.5

# ─── 可选：调优参数 ─────────────────────────────────────────
# LLM_TIMEOUT_NORMAL=120
# LLM_PARSE_CHUNK_CHARS=18000
# PADDLE_OCR_USE_CACHE=1
# PADDLE_OCR_POLL_TIMEOUT_SEC=900
